# Local TimescaleDB (docker compose), host port 5433 to avoid clashing with any local Postgres.
DATABASE_URL=postgresql://oei:oei@localhost:5433/oei

# Space-Track credentials: request a free account at https://www.space-track.org
# Never commit real credentials — this file is a template only (.env is gitignored).
SPACETRACK_IDENTITY=
SPACETRACK_PASSWORD=

# Review area write token: the shared secret the Review UI / CLI must send as the X-Review-Token
# header to POST a gold verdict (read endpoints stay open). Generate one with:
#   python -c "import secrets; print(secrets.token_hex(16))"
# and export it (source .env) before starting uvicorn. Unset ⇒ every verdict write is rejected 401.
REVIEW_TOKEN=
