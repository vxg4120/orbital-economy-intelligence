# Local TimescaleDB (docker compose), host port 5433 to avoid clashing with any local Postgres.
DATABASE_URL=postgresql://oei:oei@localhost:5433/oei

# Space-Track credentials: request a free account at https://www.space-track.org
# Never commit real credentials — this file is a template only (.env is gitignored).
SPACETRACK_IDENTITY=
SPACETRACK_PASSWORD=
