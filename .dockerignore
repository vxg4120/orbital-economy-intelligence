# Keep the build context small and reproducible. Anything the image needs is
# COPYed explicitly in the Dockerfile; everything here is dev-only or rebuildable.
.git/
**/__pycache__/
**/*.pyc
.pytest_cache/
.ruff_cache/
.venv/
.venv-*/
web/node_modules/
web/dist/
data/
scratchpad/
tasks/
tests/
docs/
*.log
.env
.env.*
