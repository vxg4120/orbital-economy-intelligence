# Copy to .env and fill in.  NEVER commit .env (see .gitignore).

# --- Postgres (single Timescale cluster holding both oei + exo) ---
# Long random string.  Generate one with:  openssl rand -hex 24
POSTGRES_PASSWORD=

# --- Domain + TLS ---
# You own BASE_DOMAIN; the apps are served at:
#   https://orbital.BASE_DOMAIN   (satellite)
#   https://exo.BASE_DOMAIN       (exodossier)
# Caddy provisions Let's Encrypt certs for both. ACME_EMAIL gets expiry notices.
BASE_DOMAIN=example.com
ACME_EMAIL=you@example.com

# --- Satellite gold-verdict write endpoint (optional) ---
# Guards the one write route (X-Review-Token). Random string; leave blank if unused.
REVIEW_TOKEN=

# --- Space-Track credentials for the nightly satellite backfill (optional) ---
# Without these the nightly refresh still pulls CelesTrak (current element sets);
# only the deep Space-Track history stops advancing.  https://www.space-track.org
SPACETRACK_IDENTITY=
SPACETRACK_PASSWORD=
