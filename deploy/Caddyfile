# Caddy reverse proxy with automatic Let's Encrypt TLS.
# {$BASE_DOMAIN} / {$ACME_EMAIL} are injected from the caddy container environment
# (set in .env). Certs auto-provision once the A records point here and 80/443 are open.

{
	email {$ACME_EMAIL}
}

# Root landing page (portfolio; /live/* proxies let the page query the apps
# same-origin so its metrics are real, no CORS needed)
{$BASE_DOMAIN} {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	handle /live/orbital {
		rewrite * /api/stats
		reverse_proxy oei-api:8600
	}
	handle /live/exo {
		rewrite * /api/stats
		reverse_proxy exo-api:8700
	}
	handle {
		root * /srv/landing
		header /fonts/* Cache-Control "public, max-age=31536000, immutable"
		file_server
	}
}

# www -> apex (canonical)
www.{$BASE_DOMAIN} {
	redir https://{$BASE_DOMAIN}{uri} permanent
}

# Satellite platform — Orbital Economy Intelligence
orbital.{$BASE_DOMAIN} {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	reverse_proxy oei-api:8600
}

# ExoDossier — exoplanet candidate vetting
exo.{$BASE_DOMAIN} {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	reverse_proxy exo-api:8700
}
